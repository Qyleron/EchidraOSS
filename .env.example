# Echidra local configuration template.
# Copy this file to .env and edit values for your machine.
# The real .env file is ignored by git so secrets stay local.

# Honeypot listener
ECHIDRA_HOST=0.0.0.0
ECHIDRA_PORT=2222
ECHIDRA_MAX_CONNECTIONS=100
ECHIDRA_READ_TIMEOUT=60

# Honeypot persona selection and JSONL session log.
# Persona definitions live in honeypot/core/persona.py; this selects one preset.
ECHIDRA_PERSONA=generic_linux
ECHIDRA_SESSION_LOG=logs/sessions.jsonl

# PostgreSQL storage for /classify/session/store
# Keep real credentials only in your local .env file.
# If your password contains URL special characters, percent-encode it first.
# Example password "p@ss/word" becomes "p%40ss%2Fword".
# ECHIDRA_DATABASE_URL=postgresql://echidra:echidra@localhost:5432/echidra
ECHIDRA_DATABASE_URL=
